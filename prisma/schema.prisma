generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes", "multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "auth"]
}

model Student {
  id                String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  admissionNumber   String             @unique @map("admission_number")
  full_name         String
  grade_level       String
  stream            String?
  phone             String?
  email             String?
  dob               String?
  gender            String?
  address           String?
  status            String?            @default("active")
  cardUid           String?            @unique @map("card_uid")
  walletBalance     Decimal?           @default(0.00) @map("wallet_balance") @db.Decimal(10, 2)
  createdAt         DateTime?          @default(now()) @map("created_at") @db.Timestamptz(6)
  attendance        Attendance[]
  feeTransactions   FeeTransaction[]
  parentStudentMaps ParentStudentMap[]
  marks             Mark[]
  fees              Fee[]
  cards             Cards[]

  @@map("students")
  @@schema("public")
}

model Parent {
  id                String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId            String?            @map("user_id") @db.Uuid
  full_name         String
  phone_number      String?            @unique
  email             String?            @unique
  address           String?
  status            String?            @default("active")
  createdAt         DateTime?          @default(now()) @map("created_at") @db.Timestamptz(6)
  appointments      Appointment[]
  parentStudentMaps ParentStudentMap[]

  @@map("parents")
  @@schema("public")
}

model Staff {
  id                String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId            String?       @map("user_id") @db.Uuid
  full_name         String
  subject_specialty String?
  phone             String?
  email             String?
  qualification     String?
  experience        String?
  status            String?       @default("active")
  classes           String? // Comma separated or JSON
  role              String?       @default("teacher")
  createdAt         DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  appointments      Appointment[]
  assignments       Assignment[]

  @@map("staff")
  @@schema("public")
}

model ParentStudentMap {
  parentId     String  @map("parent_id") @db.Uuid
  studentId    String  @map("student_id") @db.Uuid
  relationship String?
  parent       Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  student      Student @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([parentId, studentId])
  @@map("parent_student_map")
  @@schema("public")
}

model Attendance {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  studentId String?   @map("student_id") @db.Uuid
  checkType String?   @map("check_type")
  deviceId  String?   @map("device_id")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  term      String?
  student   Student?  @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("attendance")
  @@schema("public")
}

model FeeTransaction {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  studentId   String?   @map("student_id") @db.Uuid
  amount      Decimal   @db.Decimal(10, 2)
  type        String?
  description String?
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  student     Student?  @relation(fields: [studentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("fee_transactions")
  @@schema("public")
}

model Mark {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  grade     String // e.g., "Grade 10"
  term      String // e.g., "Term 1"
  math      Float    @default(0)
  english   Float    @default(0)
  science   Float    @default(0)
  history   Float    @default(0)
  average   Float    @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("marks")
  @@schema("public")
}

model Announcement {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title          String
  content        String
  priority       String   @default("low") // low, medium, high
  category       String   @default("general")
  targetAudience String   @default("all") @map("target_audience") // all, students, parents, teachers
  published      Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("announcements")
  @@schema("public")
}

model Fee {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class     String
  term      String
  amount    Decimal  @db.Decimal(10, 2)
  paid      Decimal  @default(0) @db.Decimal(10, 2)
  balance   Decimal  @db.Decimal(10, 2)
  status    String   @default("pending") // pending, partial, paid
  payments  Json? // Array of { date, amount, method, receiptNo }
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("fees")
  @@schema("public")
}

model Assignment {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  teacherId   String?   @map("teacher_id") @db.Uuid
  title       String
  description String?
  grade_level String
  dueDate     DateTime  @map("due_date") @db.Timestamptz(6)
  status      String?   @default("active")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  teacher     Staff?    @relation(fields: [teacherId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("assignments")
  @@schema("public")
}

model Appointment {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  parentId     String?   @map("parent_id") @db.Uuid
  teacherId    String?   @map("teacher_id") @db.Uuid
  scheduledAt  DateTime  @map("scheduled_at") @db.Timestamptz(6)
  status       String?   @default("pending")
  parent_notes String?
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  parent       Parent?   @relation(fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  teacher      Staff?    @relation(fields: [teacherId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("appointments")
  @@schema("public")
}

model Cards {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  identifier String   @unique
  studentId  String?  @unique @map("student_id") @db.Uuid
  student    Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("cards")
  @@schema("public")
}

enum StaffRole {
  ADMIN
  TEACHER
  ACCOUNTANT

  @@schema("public")
}

enum DevicePurpose {
  ATTENDANCE
  CANTEEN
  CLEARANCE

  @@schema("public")
}

enum TransactionType {
  CREDIT
  DEBIT

  @@schema("public")
}

enum CheckType {
  IN
  OUT

  @@schema("public")
}

enum AttendanceStatus {
  ON_TIME
  LATE

  @@schema("public")
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  MAINTENANCE

  @@schema("public")
}

enum GradeType {
  EXAM
  QUIZ
  ASSIGNMENT
  PROJECT
  PARTICIPATION

  @@schema("public")
}
